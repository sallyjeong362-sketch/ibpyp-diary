rules_version = '2';

// Firebase 콘솔 > Firestore Database > 규칙 탭에 이 내용을 붙여넣고 게시하세요.
//
// 이 앱은 로그인(Firebase Auth) 없이 "학급 코드 + 교사 비밀번호"만으로 동작하는
// 가벼운 학급용 도구입니다. 그래서 아래 규칙은 학급 코드를 아는 사람이면 누구나
// 해당 학급 문서를 읽고 쓸 수 있도록 열려 있습니다 (진짜 서버 인증이 아니라
// "코드를 아는 사람만 접근"하는 수준의 보호입니다). 민감한 개인정보(실명, 연락처 등)는
// 넣지 않는 것을 권장합니다.
service cloud.firestore {
  match /databases/{database}/documents {
    match /classes/{classId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'teacherPasswordHash'])
                    && request.resource.data.name is string
                    && request.resource.data.teacherPasswordHash is string;
      allow update, delete: if false;

      match /entries/{entryId} {
        allow read, create, update, delete: if true;
      }
    }
  }
}
