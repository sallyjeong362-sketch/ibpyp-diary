rules_version = '2';

// Firebase 콘솔 > Firestore Database > 규칙 탭에 이 내용을 붙여넣고 게시하세요.
// (그리고 Authentication > Sign-in method > 익명(Anonymous)을 반드시 켜주세요 —
//  아래 규칙은 학생/교사가 조용히 발급받는 익명 인증 uid를 기준으로 "본인 글만
//  수정/삭제 가능"을 실제로 강제합니다.)
//
// 이 앱은 이름/비밀번호 로그인 없이 "학급 코드 + 교사 비밀번호"만으로 동작하는
// 가벼운 학급용 도구입니다. 그래서 학급 코드를 아는 사람이면 누구나 학급 데이터를
// 읽고 새 글을 쓸 수 있도록 열려 있습니다 (진짜 계정 기반 인증이 아니라 "코드를
// 아는 사람만 접근"하는 수준의 보호입니다). 다만 일기 원본은 작성자 본인의 기기
// (익명 인증 uid)만 수정/삭제할 수 있도록 강제해서, 같은 반 친구가 서로의 일기를
// 볼 수 있게 된 뒤에도 서로의 글을 건드릴 수는 없게 했습니다.
service cloud.firestore {
  match /databases/{database}/documents {
    match /classes/{classId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'teacherPasswordHash'])
                    && request.resource.data.name is string
                    && request.resource.data.teacherPasswordHash is string;
      // teacherUid만 갱신 가능 (교사 로그인 성공 시 클라이언트가 자신의 uid를 기록해서
      // 이후 검토/삭제 권한 확인에 사용). 비밀번호 자체는 규칙에서 검증할 수 없으므로
      // 여기서도 "코드를 아는 사람 수준"의 보호이며, 학생 데이터 보호가 핵심 목적입니다.
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teacherUid']);
      allow delete: if false;

      match /entries/{entryId} {
        allow read: if true;
        allow create: if request.auth != null
                      && request.resource.data.ownerUid == request.auth.uid;
        // 본인은 무엇이든 수정 가능. 교사는 reviewed/teacherComment(검토 결과)만 수정 가능 —
        // 일기 원문(lines/text/photo 등)은 교사도 건드릴 수 없습니다.
        allow update: if request.auth != null && (
          resource.data.ownerUid == request.auth.uid ||
          (get(/databases/$(database)/documents/classes/$(classId)).data.teacherUid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reviewed', 'teacherComment', 'updatedAt']))
        );
        // 삭제는 작성자 본인 또는 학급 교사만 (부적절한 글 관리용).
        allow delete: if request.auth != null && (
          resource.data.ownerUid == request.auth.uid ||
          get(/databases/$(database)/documents/classes/$(classId)).data.teacherUid == request.auth.uid
        );

        match /comments/{commentId} {
          allow read: if true;
          allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
          allow update: if false;
          // 댓글은 작성자 본인 또는 교사가 삭제 가능 (모욕적인 댓글 등 관리용).
          allow delete: if request.auth != null && (
            resource.data.ownerUid == request.auth.uid ||
            get(/databases/$(database)/documents/classes/$(classId)).data.teacherUid == request.auth.uid
          );
        }
      }
    }
  }
}
